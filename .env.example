# ─── Job API Keys (OPTIONAL — system works without these) ─────────────────────
# Without keys: LinkedIn + Naukri + Remotive scrapers still run (free, no key needed).

# Adzuna — free 1000 req/month — register at https://developer.adzuna.com
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# JSearch via RapidAPI — free 200 req/month — https://rapidapi.com/letscrape-6bRBa3QguO5/api/jsearch
RAPIDAPI_KEY=

# ─── Email Notifications (OPTIONAL) ──────────────────────────────────────────
# Gmail only. Enable 2FA → Security → App Passwords → generate one.
# Leave blank to disable email digests (use dashboard instead).
SMTP_EMAIL=
SMTP_PASSWORD=
NOTIFY_EMAIL=hardik.kolge.it@gmail.com

# ─── LinkedIn Automation (OPTIONAL) ──────────────────────────────────────────
# Used for auto-sending connection requests + messages to recruiters.
# After adding creds, run the server once and open http://localhost:8000 —
# LinkedIn may require manual 2FA on first login (check data/linkedin_session/)
LINKEDIN_EMAIL=
LINKEDIN_PASSWORD=

# ─── HR Email Finder (OPTIONAL) ───────────────────────────────────────────────
# Hunter.io — free 25 searches/month — https://hunter.io/api
HUNTER_API_KEY=

# ─── Auto-Apply Settings ─────────────────────────────────────────────────────
AUTO_APPLY_ENABLED=false          # set true to send real emails
AUTO_APPLY_MIN_SCORE=85           # only auto-apply to jobs scoring >= this
AUTO_APPLY_INTERVAL_HOURS=24      # how often to run auto-apply cycle

# ─── Scheduler Settings ───────────────────────────────────────────────────────
SCRAPE_INTERVAL_HOURS=12
DIGEST_EMAIL_HOUR=9
