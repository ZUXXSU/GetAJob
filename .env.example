# ─── Personal Profile (REQUIRED) ──────────────────────────────────────────────
# Everything personal lives in this file. Nothing is hardcoded in the codebase.
CANDIDATE_NAME=Your Full Name
CANDIDATE_EMAIL=you@example.com
CANDIDATE_PHONE=+91 9999999999
CANDIDATE_LINKEDIN=linkedin.com/in/your-handle
CANDIDATE_GITHUB=github.com/your-handle
CANDIDATE_LOCATION=Your City, State, Country
CANDIDATE_LOCATION_TARGETS=city1,city2,city3
CANDIDATE_ACCEPT_REMOTE=true
CANDIDATE_MIN_SALARY_INR=500000
CANDIDATE_EXP_YEARS=1.5
CANDIDATE_SKILLS=python,javascript,react,node,sql
CANDIDATE_TARGET_ROLES=software engineer,full stack developer
CANDIDATE_TARGET_INDUSTRIES=technology,saas,fintech
CANDIDATE_SEARCH_QUERIES=software engineer,full stack developer,backend developer

# Optional form-fill answers (used by autofill kit)
CANDIDATE_CURRENT_COMPANY=
CANDIDATE_CURRENT_TITLE=Developer
CANDIDATE_COUNTRY=India
CANDIDATE_NOTICE_PERIOD_DAYS=30
CANDIDATE_RELOCATE=No
CANDIDATE_WORK_AUTH=Citizen
CANDIDATE_NEEDS_SPONSORSHIP=No
CANDIDATE_WEBSITE=

# Resume PDF — drop a file at this path (or default location: data/resumes/default.pdf)
DEFAULT_RESUME_PDF=

# ─── Email / SMTP (REQUIRED for auto-apply and digests) ──────────────────────
# Gmail App Password: https://myaccount.google.com/apppasswords
SMTP_EMAIL=
SMTP_PASSWORD=
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
NOTIFY_EMAIL=

# ─── Job API Keys (OPTIONAL) ─────────────────────────────────────────────────
# Adzuna — https://developer.adzuna.com (free 1000 req/month)
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# JSearch via RapidAPI — https://rapidapi.com (subscribe to JSearch BASIC plan)
RAPIDAPI_KEY=

# Hunter.io — https://hunter.io/api (free 25 searches/month, finds HR emails)
HUNTER_API_KEY=

# ─── LinkedIn Messaging (OPTIONAL) ───────────────────────────────────────────
LINKEDIN_EMAIL=
LINKEDIN_PASSWORD=

# ─── Telegram Notifications (OPTIONAL) ───────────────────────────────────────
# Create bot via @BotFather → /newbot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ─── WhatsApp via Twilio (OPTIONAL) ──────────────────────────────────────────
# https://www.twilio.com/console/sms/whatsapp/sandbox
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
TWILIO_WHATSAPP_TO=

# ─── Slack Notifications (OPTIONAL) ──────────────────────────────────────────
# Slack → Apps → Incoming Webhooks → create
SLACK_WEBHOOK_URL=

# ─── Auto-Apply Settings ─────────────────────────────────────────────────────
AUTO_APPLY_ENABLED=false          # set true to send real emails
AUTO_APPLY_MIN_SCORE=85           # only jobs scoring this high
AUTO_APPLY_INTERVAL_HOURS=24

# ─── Filters ─────────────────────────────────────────────────────────────────
BLACKLIST_COMPANIES=
BLACKLIST_KEYWORDS=unpaid,commission only,mlm,network marketing
WEEKLY_APPLY_GOAL=10

# ─── Scheduler ───────────────────────────────────────────────────────────────
SCRAPE_INTERVAL_HOURS=12
DIGEST_EMAIL_HOUR=9
WEEKLY_REPORT_ENABLED=true

# ─── Gemini CLI ──────────────────────────────────────────────────────────────
# Install: https://github.com/google-gemini/gemini-cli
GEMINI_BIN=/usr/local/bin/gemini
